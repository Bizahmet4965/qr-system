# Bu dosyayı kopyalayıp .env olarak kaydet:
#   cp .env.example .env
# Sonra değerleri düzenle.

# MariaDB / MySQL bağlantı dizesi
DATABASE_URL=mysql://qruser:SIFREN@localhost:3306/qrdb

# İlk admin bilgileri (yalnızca users tablosu BOŞken okunur)
ADMIN_USER=admin
ADMIN_PASS=degistir-beni

# QR kodlara basılacak tam adres (telefon kamerasıyla açılması için HTTPS zorunlu)
# LAN IP'ni veya alan adını yaz:
BASE_URL=https://192.168.X.X:3000
